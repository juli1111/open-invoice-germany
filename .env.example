# ── OpenInvoice Germany — Beispiel-Umgebung ──────────────────────────────
# Kopiere diese Datei nach .env und passe die Werte an.

# Datenbank ---------------------------------------------------------------
# Solo/Dev (Default): lokale SQLite-Datei, kein Server nötig.
DATABASE_URL="file:./dev.db"
#
# Postgres (Docker/Prod): siehe docker-compose.yml + prisma/schema.postgres.prisma
# DATABASE_URL="postgresql://oig:oig@localhost:5432/openinvoice?schema=public"

# E-Rechnung-Validierung (optional) --------------------------------------
# Mustangproject-Sidecar (Docker) für XRechnung/ZUGFeRD-Erzeugung & -Validierung.
# Ohne diesen Dienst kann die App nur "sonstige Rechnungen" (PDF) ausstellen.
# EINVOICE_SERVICE_URL="http://localhost:8085"

# E-Mail-Versand (optional, später) --------------------------------------
# RESEND_API_KEY=""
# MAIL_FROM="rechnung@example.de"
